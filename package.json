{
  "name": "ai-genius-ep2-speckit",
  "version": "1.0.0",
  "description": "Agentic DevOps with SpecKit: Turn Specs into CI/CD Using GitHub Actions",
  "main": "src/ai-genius-web/server.js",
  "bin": {
    "speckit": "./speckit/index.js"
  },
  "scripts": {
    "start": "node src/ai-genius-web/server.js",
    "dev": "node --watch src/ai-genius-web/server.js",
    "lint": "eslint .",
    "test": "jest --forceExit",
    "test:coverage": "jest --coverage --forceExit",
    "speckit": "node speckit/index.js",
    "speckit:validate": "node speckit/index.js validate specs/app.spec.yaml",
    "speckit:generate": "node speckit/index.js generate specs/app.spec.yaml --output .github/workflows/generated-pipeline.yml",
    "speckit:run": "node speckit/index.js run specs/app.spec.yaml"
  },
  "keywords": [
    "speckit",
    "devops",
    "github-actions",
    "agentic-ai",
    "cicd",
    "automation"
  ],
  "author": "AI Genius",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "js-yaml": "^4.1.0",
    "chalk": "^4.1.2",
    "commander": "^11.1.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
